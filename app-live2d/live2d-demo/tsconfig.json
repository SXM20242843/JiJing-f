{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@framework/*": ["../Framework/src/*"]
    }
  },
  "include": [
    "src",
    "../Framework/src/**/*.ts",
    "../Core/live2dcubismcore.d.ts"
  ]
}